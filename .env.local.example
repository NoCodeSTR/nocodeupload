# =============================================================================
# NoCode Upload — environment variables
# Copy this file to .env.local for local dev. Set the same vars in Vercel for prod.
# =============================================================================

# --- Supabase --------------------------------------------------------------
# Find these at: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth (server-side) -------------------------------------------
# Create at: https://console.cloud.google.com/apis/credentials
# Type: "OAuth client ID" -> "Web application"
# Authorized redirect URIs must include (use the CANONICAL production host):
#   http://localhost:3000/api/google/callback
#   https://<canonical-host>/api/google/callback
# IMPORTANT: the redirect URI must EXACTLY match the canonical host the app runs
# on (www vs apex). Canonical host is currently UNRESOLVED — Sean's shared links
# use www.nocodeupload.com but these examples use the apex. Pick one and make
# DNS + NEXT_PUBLIC_APP_URL + GOOGLE_REDIRECT_URI + Google Cloud all agree, or
# connecting Google will fail with redirect_uri_mismatch. See docs/DECISIONS.md ADR-15.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# --- Google Picker (browser-safe, but still keep restricted) --------------
# Same OAuth client ID as above; the picker uses it client-side.
# The API key is a separate "API key" credential restricted by HTTP referrer.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=
NEXT_PUBLIC_GOOGLE_PROJECT_NUMBER=

# --- Token encryption ------------------------------------------------------
# AES-256-GCM key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 64 hex characters (32 bytes). MUST be stable across deploys; rotating breaks
# all stored refresh tokens.
TOKEN_ENCRYPTION_KEY=

# --- App -------------------------------------------------------------------
# In production set this to the CANONICAL host (must match GOOGLE_REDIRECT_URI's
# host and the Google Cloud OAuth config). See docs/DECISIONS.md ADR-15.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional: email notifications via Resend -----------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@nocodeupload.com

# --- Airtable / Slack / Quo -----------------------------------------------
# These are NOT env vars: Airtable (Personal Access Token), Slack (bot), and Quo
# (OpenPhone API key) are connected per-user/per-destination through the app UI
# and stored (encrypted) in the database. Nothing to set here.

# --- DEPRECATED: Upstash Redis (no longer used) ---------------------------
# Rate limiting is now DB-based (lib/rate-limit.ts counts rows in `uploads`);
# it needs NO external infra. These vars + the @upstash/* packages are vestigial
# and can be removed. Leaving blank/absent has no effect. (features().rateLimit
# in lib/env.ts is also vestigial.) See docs/TECHNICAL-DEBT.md.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
